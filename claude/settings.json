{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/approve-readonly-bash.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__scrapling__fetch",
      "mcp__scrapling__stealthy_fetch",
      "mcp__scrapling__get",
      "mcp__scrapling__bulk_fetch",
      "mcp__scrapling__bulk_get",
      "mcp__scrapling__bulk_stealthy_fetch",
      "WebSearch"
    ],
    "deny": ["WebFetch"]
  },
  "enabledMcpjsonServers": [
    "codex",
    "scrapling"
  ]
}
